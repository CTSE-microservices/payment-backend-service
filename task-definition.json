{
    "containerDefinitions": [
        {
            "name": "payment",
            "image": "103608802257.dkr.ecr.eu-north-1.amazonaws.com/payment-backend-service:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 3001,
                    "hostPort": 3001,
                    "protocol": "tcp",
                    "name": "payment-3001-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "PORT",
                    "value": "3001"
                },
                {
                    "name": "JWT_EXPIRES_IN",
                    "value": "7d"
                },
                {
                    "name": "FRONTEND_URL",
                    "value": "http://payment-alb-1735044991.eu-north-1.elb.amazonaws.com"
                },
                {
                    "name": "ORDER_SERVICE_URL",
                    "value": "http://payment-alb-1735044991.eu-north-1.elb.amazonaws.com"
                },
                {
                    "name": "DATABASE_URL",
                    "value": "__DATABASE_URL__"
                },
                {
                    "name": "JWT_SECRET",
                    "value": "__JWT_SECRET__"
                },
                {
                    "name": "RABBITMQ_URL",
                    "value": "__RABBITMQ_URL__"
                },
                {
                    "name": "STRIPE_SECRET_KEY",
                    "value": "__STRIPE_SECRET_KEY__"
                },
                {
                    "name": "STRIPE_WEBHOOK_SECRET",
                    "value": "__STRIPE_WEBHOOK_SECRET__"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/payment-service-task",
                    "awslogs-create-group": "true",
                    "awslogs-region": "eu-north-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "payment-service-task",
    "executionRoleArn": "arn:aws:iam::103608802257:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512"
}
