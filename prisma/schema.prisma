generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["order", "payment"]
}

model cart {
  id              Int         @id @default(autoincrement())
  user_uuid       String      @db.Uuid
  discount_id     Int?
  discount_amount Float?      @default(0)
  created_by      String?     @db.Uuid
  updated_by      String?     @db.Uuid
  created_at      DateTime?   @default(now()) @db.Timestamp(6)
  updated_at      DateTime?   @default(now()) @db.Timestamp(6)
  is_deleted      Boolean?    @default(false)
  deleted_at      DateTime?   @db.Timestamp(6)
  discount        discount?   @relation(fields: [discount_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cart_discount")
  cart_item       cart_item[]

  @@index([user_uuid], map: "idx_cart_user_uuid")
  @@schema("order")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_item {
  id           Int       @id @default(autoincrement())
  cart_id      Int
  product_id   String    @db.VarChar(100)
  product_name String    @db.VarChar(255)
  quantity     Int
  unit_price   Decimal   @db.Decimal(10, 2)
  total_price  Decimal?  @default(dbgenerated("((quantity)::numeric * unit_price)")) @db.Decimal(12, 2)
  created_by   String?   @db.Uuid
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  is_deleted   Boolean?  @default(false)
  deleted_at   DateTime? @db.Timestamp(6)
  cart         cart      @relation(fields: [cart_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cart")

  @@index([cart_id], map: "idx_cart_item_cart_id")
  @@schema("order")
}

model discount {
  id                  Int       @id @default(autoincrement())
  code                String    @unique @db.VarChar(50)
  type                String    @db.VarChar(20)
  value               Decimal   @db.Decimal(10, 2)
  min_order_amount    Decimal?  @db.Decimal(12, 2)
  max_discount_amount Decimal?  @db.Decimal(12, 2)
  is_active           Boolean?  @default(true)
  starts_at           DateTime? @db.Timestamp(6)
  expires_at          DateTime? @db.Timestamp(6)
  metadata            Json?
  created_by          String?   @db.Uuid
  updated_by          String?   @db.Uuid
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at          DateTime? @default(now()) @db.Timestamp(6)
  is_deleted          Boolean?  @default(false)
  deleted_at          DateTime? @db.Timestamp(6)
  cart                cart[]
  orders              orders[]

  @@index([code], map: "idx_discount_code")
  @@schema("order")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_item {
  id           Int       @id @default(autoincrement())
  order_id     Int
  product_id   String    @db.VarChar(100)
  product_name String    @db.VarChar(255)
  quantity     Int
  unit_price   Decimal   @db.Decimal(10, 2)
  total_price  Decimal   @db.Decimal(12, 2)
  created_by   String?   @db.Uuid
  is_deleted   Boolean?  @default(false)
  deleted_at   DateTime? @db.Timestamp(6)
  orders       orders    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order")

  @@index([order_id], map: "idx_order_item_order_id")
  @@schema("order")
}

model order_status {
  id                   Int                    @id @default(autoincrement())
  code                 String                 @unique @db.VarChar(50)
  description          String?                @db.VarChar(255)
  created_by           String?                @db.Uuid
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  is_deleted           Boolean?               @default(false)
  deleted_at           DateTime?              @db.Timestamp(6)
  type                 String?
  order_status_history order_status_history[]
  orders               orders[]
  payments             payments[]
  refunds              refunds[]

  @@schema("order")
}

model order_status_history {
  id           Int          @id @default(autoincrement())
  order_id     Int
  status_id    Int
  changed_by   String?      @db.Uuid
  metadata     Json?
  changed_at   DateTime?    @default(now()) @db.Timestamp(6)
  is_deleted   Boolean?     @default(false)
  deleted_at   DateTime?    @db.Timestamp(6)
  orders       orders       @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order_status_hist_order")
  order_status order_status @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_status_hist_status")

  @@index([order_id], map: "idx_order_status_hist_order_id")
  @@schema("order")
}

model orders {
  id                   Int                    @id @default(autoincrement())
  user_uuid            String                 @db.Uuid
  status_id            Int
  total_amount         Decimal                @db.Decimal(12, 2)
  discount_id          Int?
  discount_amount      Decimal?               @default(0) @db.Decimal(12, 2)
  final_amount         Decimal                @db.Decimal(12, 2)
  payment_id           String?                @db.VarChar(100)
  tracking_id          String?                @db.VarChar(100)
  created_by           String?                @db.Uuid
  updated_by           String?                @db.Uuid
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  updated_at           DateTime?              @default(now()) @db.Timestamp(6)
  is_deleted           Boolean?               @default(false)
  deleted_at           DateTime?              @db.Timestamp(6)
  order_item           order_item[]
  order_status_history order_status_history[]
  discount             discount?              @relation(fields: [discount_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_discount")
  order_status         order_status           @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_status")
  payments             payments[]

  @@index([status_id], map: "idx_orders_status_id")
  @@index([user_uuid], map: "idx_orders_user_uuid")
  @@schema("order")
}

model payments {
  id             Int           @id @default(autoincrement())
  payment_code   String?
  order_id       Int?
  user_uuid      String?
  amout          Decimal?      @db.Decimal
  currency       String?
  payment_method String?
  status         Int?
  gateway        String?
  created_at     DateTime?     @default(now()) @db.Timetz(6)
  updated_at     DateTime?     @db.Timetz(6)
  extra          Json?         @db.Json
  orders         orders?       @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  order_status   order_status? @relation(fields: [status], references: [id], onDelete: NoAction, onUpdate: NoAction)
  refunds        refunds[]

  @@schema("payment")
}

model refunds {
  id               Int           @id @default(autoincrement())
  refund_code      String?
  payment_id       Int?
  stripe_refund_id Int?
  refund_amount    Decimal?      @db.Decimal
  reason           String?
  status           Int?
  created_at       DateTime?     @db.Timetz(6)
  created_by       String?       @default(dbgenerated("CURRENT_TIMESTAMP"))
  reviewed_by      String?
  reviewed_at      DateTime?     @db.Timestamptz(6)
  payments         payments?     @relation(fields: [payment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  order_status     order_status? @relation(fields: [status], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("payment")
}

model payment_log {
  id         Int       @id @default(autoincrement())
  payment_id Int?
  event_type String?
  payload    Json?     @db.Json
  created_at DateTime? @default(now()) @db.Timetz(6)

  @@schema("payment")
}
